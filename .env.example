# OpenAI / LLM configuration
OPENAI_API_KEY=replace_with_your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.0

# Scraper configuration
JUMIA_BASE_URL=https://www.jumia.com.ng
JUMIA_CATEGORY_URL=https://www.jumia.com.ng/mobile-accessories/
SCRAPER_MAX_PAGES=5
SCRAPER_MAX_PRODUCTS=100
SCRAPER_MAX_REVIEWS_PER_PRODUCT=100
SCRAPER_MAX_REVIEW_PAGES_PER_PRODUCT=10
SCRAPER_MIN_LISTING_REVIEW_COUNT=1
SCRAPER_MIN_DELAY_SECONDS=2
SCRAPER_MAX_DELAY_SECONDS=6
SCRAPER_TIMEOUT_SECONDS=20
SCRAPER_MAX_RETRIES=3

# File paths
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
FIGURES_DIR=reports/figures

# Streamlit configuration
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0

# Pipeline configuration
PIPELINE_MODE=llm

# Deployment configuration
DASHBOARD_HOST=dashboard.poshlovesdata.dev
TRAEFIK_NETWORK=web
